    "# Churn rate by cluster (x100) + cross-check with the rule-based segments\n",
    "rate = base_seg.groupby(\"cluster\")[\"churn\"].mean().mul(100)\n",
    "fig, axes = plt.subplots(1, 2, figsize=(13, 4.4))\n",
