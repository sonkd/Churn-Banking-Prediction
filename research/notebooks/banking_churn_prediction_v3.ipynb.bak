    "    axes[1].plot(rec, prec, ls=STYLES[name], lw=1.8, label=f\"{name} (AP={average_precision_score(y_test, p):.3f})\")\n",
    "axes[0].plot([0, 1], [0, 1], c=\"gray\", lw=.8, ls=\"--\")\n",
    "axes[0].set(xlim=(0, .4), ylim=(.5, 1.005), xlabel=\"FPR\", ylabel=\"TPR\", title=\"ROC — zoomed\")\n",
